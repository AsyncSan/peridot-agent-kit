# Database — same connection string as defi-platform
DATABASE_URL=postgres://user:password@host:25060/db?sslmode=require

# Optional: use DigitalOcean CA cert for full SSL verification (recommended in production)
# PGSSLROOTCERT=/path/to/ca-certificate.crt
# PGSSLSERVERNAME=db-hostname.db.ondigitalocean.com

# Local SSH tunnel only: set to "false" to skip cert verification when tunneling
# (e.g. ssh -L 5433:private-host:25060 bastion). Never use in production.
# DB_SSL_REJECT_UNAUTHORIZED=false

# Server
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated origins, or * to allow all
CORS_ORIGIN=*

# Network preset — determines which DB tables to use
# mainnet → apy_latest_mainnet, asset_metrics_latest_mainnet, etc.
# testnet → apy_latest, asset_metrics_latest, etc.
NETWORK_PRESET=mainnet
